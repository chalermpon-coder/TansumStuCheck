<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>ระบบเช็คชื่อนักเรียน - โรงเรียนตาลสุมพัฒนา</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Sarabun', sans-serif;
            background-color: #f8fafc;
            -webkit-tap-highlight-color: transparent;
        }
        .status-btn.active-present { background-color: #10b981; color: white; border-color: #10b981; }
        .status-btn.active-absent { background-color: #ef4444; color: white; border-color: #ef4444; }
        .status-btn.active-leave { background-color: #f59e0b; color: white; border-color: #f59e0b; }
        .status-btn.active-escape { background-color: #6366f1; color: white; border-color: #6366f1; }
        
        .sticky-header {
            position: sticky;
            top: 0;
            z-index: 20;
            background: white;
        }

        .stats-card {
            transition: all 0.3s ease;
        }
        
        .history-badge {
            font-size: 9px;
            padding: 1px 4px;
            border-radius: 4px;
            font-weight: 600;
        }
    </style>
</head>
<body class="bg-slate-50 min-h-screen flex flex-col">

    <!-- ส่วนหัวของเว็บไซต์ -->
    <header class="bg-blue-700 text-white shadow-md sticky top-0 z-50">
        <div class="max-w-5xl mx-auto px-4 py-3 flex justify-between items-center">
            <div class="flex items-center space-x-3">
                <div class="bg-white p-1 rounded-full shadow-inner">
                    <img src="https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEjI0mI8mVdZ8bTd7lRNECkKyeQ-aEhHl1zdBM3xAK9ftcmrDIHpFyFdQ6_lZQT34FAFUGGnTVrnGvxR68J3-nWKaNLEptXX9Uvo7GnML4Nhe2mcwDp-w3NAHSPB1fXMKzJjEEUqsg_KkuQ/s1600/1034711153.gif" alt="โลโก้โรงเรียน" class="w-10 h-10 object-contain" onerror="this.src='https://via.placeholder.com/40?text=Logo'">
                </div>
                <div>
                    <h1 class="text-base md:text-xl font-bold">เช็คชื่อนักเรียน</h1>
                    <p class="text-blue-200 text-[10px]">โรงเรียนตาลสุมพัฒนา</p>
                </div>
            </div>
            <div id="currentTime" class="text-xs font-medium bg-blue-800 px-3 py-1.5 rounded-full border border-blue-600">--:--</div>
        </div>
    </header>

    <main class="flex-grow max-w-5xl w-full mx-auto px-2 md:px-4 py-4 space-y-4">
        
        <!-- ส่วนเลือกวิชาและห้อง -->
        <section class="bg-white rounded-xl shadow-sm border border-slate-200 p-4">
            <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
                <div class="col-span-1">
                    <label class="block text-[10px] font-semibold text-slate-500 mb-1 ml-1">วิชา</label>
                    <select id="subjectSelect" class="w-full bg-slate-50 border border-slate-300 rounded-lg p-3 text-sm outline-none focus:ring-2 focus:ring-blue-500">
                        <option value="">รอโหลดข้อมูล...</option>
                    </select>
                </div>
                <div class="col-span-1">
                    <label class="block text-[10px] font-semibold text-slate-500 mb-1 ml-1">ห้อง/กลุ่ม</label>
                    <select id="roomSelect" class="w-full bg-slate-50 border border-slate-300 rounded-lg p-3 text-sm outline-none focus:ring-2 focus:ring-blue-500">
                        <option value="">รอโหลดข้อมูล...</option>
                    </select>
                </div>
                <div class="col-span-2 md:col-span-1">
                    <label class="hidden md:block text-xs mb-1">&nbsp;</label>
                    <button onclick="fetchStudents()" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-4 rounded-lg transition-all shadow-md flex items-center justify-center">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                        โหลดรายชื่อ
                    </button>
                </div>
            </div>
        </section>

        <!-- ส่วนแสดงรายชื่อนักเรียน -->
        <section class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden flex flex-col min-h-[400px]">
            <div id="loading" class="hidden flex-grow flex flex-col items-center justify-center py-20">
                <div class="animate-spin rounded-full h-10 w-10 border-4 border-blue-600 border-t-transparent mb-4"></div>
                <p id="loadingText" class="text-slate-500">กำลังเชื่อมต่อข้อมูล...</p>
            </div>

            <div id="studentTableContainer" class="hidden flex-grow flex flex-col">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-200">
                        <thead class="bg-slate-50 sticky-header shadow-sm">
                            <tr>
                                <th class="px-3 py-4 text-center text-[10px] font-bold text-slate-500 uppercase w-12">No.</th>
                                <th class="px-3 py-4 text-left text-[10px] font-bold text-slate-500 uppercase">ชื่อ-นามสกุล / สถิติเดิม</th>
                                <th class="px-3 py-4 text-center text-[10px] font-bold text-slate-500 uppercase">สถานะวันนี้</th>
                            </tr>
                        </thead>
                        <tbody id="studentList" class="bg-white divide-y divide-slate-100"></tbody>
                    </table>
                </div>

                <!-- ส่วนสรุปสถิติ -->
                <div id="statsSummary" class="p-4 bg-slate-50 border-t border-b border-slate-200">
                    <h3 class="text-xs font-bold text-slate-500 uppercase mb-3 px-1">สรุปการเข้าเรียนวันนี้</h3>
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                        <div class="bg-white p-3 rounded-lg border border-emerald-100 shadow-sm stats-card">
                            <div class="text-[10px] font-bold text-emerald-600 uppercase">มาเรียน</div>
                            <div class="flex items-baseline space-x-1">
                                <span id="statPresentCount" class="text-xl font-bold text-emerald-700">0</span>
                                <span class="text-[10px] text-slate-400">คน</span>
                            </div>
                            <div id="statPresentPct" class="text-[9px] text-emerald-500 mt-1">0%</div>
                        </div>
                        <div class="bg-white p-3 rounded-lg border border-red-100 shadow-sm stats-card">
                            <div class="text-[10px] font-bold text-red-600 uppercase">ขาดเรียน</div>
                            <div class="flex items-baseline space-x-1">
                                <span id="statAbsentCount" class="text-xl font-bold text-red-700">0</span>
                                <span class="text-[10px] text-slate-400">คน</span>
                            </div>
                            <div id="statAbsentPct" class="text-[9px] text-red-500 mt-1">0%</div>
                        </div>
                        <div class="bg-white p-3 rounded-lg border border-amber-100 shadow-sm stats-card">
                            <div class="text-[10px] font-bold text-amber-600 uppercase">ลา</div>
                            <div class="flex items-baseline space-x-1">
                                <span id="statLeaveCount" class="text-xl font-bold text-amber-700">0</span>
                                <span class="text-[10px] text-slate-400">คน</span>
                            </div>
                            <div id="statLeavePct" class="text-[9px] text-amber-500 mt-1">0%</div>
                        </div>
                        <div class="bg-white p-3 rounded-lg border border-indigo-100 shadow-sm stats-card">
                            <div class="text-[10px] font-bold text-indigo-600 uppercase">หลบหนี</div>
                            <div class="flex items-baseline space-x-1">
                                <span id="statEscapeCount" class="text-xl font-bold text-indigo-700">0</span>
                                <span class="text-[10px] text-slate-400">คน</span>
                            </div>
                            <div id="statEscapePct" class="text-[9px] text-indigo-500 mt-1">0%</div>
                        </div>
                    </div>
                    <div class="mt-3 text-center">
                        <span class="text-[10px] text-slate-400 font-medium">รวมนักเรียนทั้งหมด <span id="totalStudentsCount" class="font-bold text-slate-600">0</span> คน</span>
                    </div>
                </div>

                <div class="p-4 bg-white mt-auto">
                    <button onclick="submitAttendance()" id="submitBtn" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-4 rounded-xl shadow-lg transition-all flex items-center justify-center text-lg">
                        บันทึกการเช็คชื่อ
                    </button>
                </div>
            </div>

            <div id="emptyState" class="flex-grow flex flex-col items-center justify-center py-20 px-6 text-center">
                <div class="bg-blue-50 p-4 rounded-full mb-4">
                    <svg class="w-12 h-12 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path></svg>
                </div>
                <h3 class="text-slate-600 font-bold text-lg">ยินดีต้อนรับ</h3>
                <p class="text-slate-400 mt-1">กรุณาเลือกวิชาและห้องเรียนเพื่อเริ่มบันทึกข้อมูล</p>
            </div>
        </section>
    </main>

    <!-- หน้าต่างแจ้งเตือน -->
    <div id="statusModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm hidden flex items-end sm:items-center justify-center p-4 z-[100]">
        <div class="bg-white rounded-2xl p-6 w-full max-w-md shadow-2xl">
            <div id="modalIcon" class="mb-4 text-5xl text-center"></div>
            <h3 id="modalTitle" class="text-xl font-bold text-slate-800 text-center mb-2"></h3>
            <p id="modalMessage" class="text-slate-500 text-center mb-8"></p>
            <button onclick="closeModal()" class="w-full bg-slate-800 hover:bg-slate-700 text-white py-4 rounded-xl font-bold transition-colors">ปิด</button>
        </div>
    </div>

    <script>
        const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbySPQSKS9VAQ7UY7XRDrv3YF4rfXe1CsxhqOOanFB8vF6fFODrAP6Cn7YMma7kcACjCYg/exec"; 

        let studentData = [];

        function requestJSONP(url) {
            return new Promise((resolve, reject) => {
                const callbackName = `jsonp_cb_${Math.round(Math.random() * 1000000)}`;
                const script = document.createElement('script');
                const timeoutId = setTimeout(() => { cleanup(); reject(new Error('Timeout')); }, 20000);
                function cleanup() { clearTimeout(timeoutId); if (script.parentNode) script.parentNode.removeChild(script); delete window[callbackName]; }
                window[callbackName] = function(data) { cleanup(); resolve(data); };
                script.onerror = () => { cleanup(); reject(new Error('JSONP Failed')); };
                const sep = url.indexOf('?') === -1 ? '?' : '&';
                script.src = `${url}${sep}prefix=${callbackName}`;
                document.body.appendChild(script);
            });
        }

        async function initApp() {
            try {
                const result = await requestJSONP(`${SCRIPT_URL}?action=getInitialData`);
                if (result.status === 'success') {
                    updateDropdown('subjectSelect', result.subjects, "เลือกวิชา...");
                    updateDropdown('roomSelect', result.rooms, "เลือกห้อง...");
                }
            } catch (error) {
                console.error("Init Error:", error);
            }
        }

        function updateDropdown(id, items, defaultText) {
            const el = document.getElementById(id);
            el.innerHTML = `<option value="">${defaultText}</option>`;
            if (items) items.forEach(item => {
                const opt = document.createElement('option');
                opt.value = item; opt.textContent = item;
                el.appendChild(opt);
            });
        }

        async function fetchStudents() {
            const room = document.getElementById('roomSelect').value;
            const subject = document.getElementById('subjectSelect').value;
            if (!room || !subject) return;

            toggleLoading(true, "กำลังดึงรายชื่อและสถิติ...");
            try {
                const result = await requestJSONP(`${SCRIPT_URL}?action=getStudents&room=${encodeURIComponent(room)}&subject=${encodeURIComponent(subject)}`);
                if (result.status === 'success') {
                    studentData = result.students.map(s => ({ ...s, status: 'present' }));
                    renderStudents();
                    updateStats();
                }
            } catch (error) {
                showModal("ข้อผิดพลาด", "ไม่สามารถดึงข้อมูลได้", "❌");
            } finally {
                toggleLoading(false);
            }
        }

        function renderStudents() {
            const list = document.getElementById('studentList');
            list.innerHTML = '';
            
            studentData.forEach((student, index) => {
                const row = document.createElement('tr');
                row.className = "hover:bg-slate-50 transition-colors";
                
                // คำนวณสีและสถิติเดิม (ถ้ามีข้อมูลส่งมาจาก Apps Script)
                const historyHtml = student.history ? `
                    <div class="flex gap-1 mt-1">
                        <span class="history-badge bg-emerald-50 text-emerald-600">มา ${student.history.present || 0}</span>
                        <span class="history-badge bg-red-50 text-red-600">ขาด ${student.history.absent || 0}</span>
                        <span class="history-badge bg-amber-50 text-amber-600">ลา ${student.history.leave || 0}</span>
                    </div>
                ` : '';

                row.innerHTML = `
                    <td class="px-2 py-4 text-sm text-slate-400 text-center border-r border-slate-50">${student.no}</td>
                    <td class="px-3 py-4">
                        <div class="text-sm font-semibold text-slate-800">${student.name}</div>
                        ${historyHtml}
                    </td>
                    <td class="px-2 py-4">
                        <div class="flex items-center justify-center gap-1">
                            ${['present', 'absent', 'leave', 'escape'].map(st => `
                                <button onclick="updateStatus(${index}, '${st}')" 
                                    class="status-btn w-10 h-10 flex items-center justify-center rounded-lg border-2 border-slate-100 text-slate-400 font-bold transition-all shadow-sm ${student.status === st ? 'active-' + st : ''}">
                                    <span class="text-[10px]">${st === 'present' ? 'มา' : st === 'absent' ? 'ขาด' : st === 'leave' ? 'ลา' : 'หลบ'}</span>
                                </button>
                            `).join('')}
                        </div>
                    </td>
                `;
                list.appendChild(row);
            });
            document.getElementById('studentTableContainer').classList.remove('hidden');
            document.getElementById('emptyState').classList.add('hidden');
        }

        function updateStatus(index, newStatus) {
            studentData[index].status = newStatus;
            renderStudents();
            updateStats();
        }

        function updateStats() {
            const total = studentData.length;
            if (total === 0) return;
            const counts = {
                present: studentData.filter(s => s.status === 'present').length,
                absent: studentData.filter(s => s.status === 'absent').length,
                leave: studentData.filter(s => s.status === 'leave').length,
                escape: studentData.filter(s => s.status === 'escape').length
            };
            const getPct = (count) => ((count / total) * 100).toFixed(1) + '%';
            document.getElementById('statPresentCount').innerText = counts.present;
            document.getElementById('statPresentPct').innerText = getPct(counts.present);
            document.getElementById('statAbsentCount').innerText = counts.absent;
            document.getElementById('statAbsentPct').innerText = getPct(counts.absent);
            document.getElementById('statLeaveCount').innerText = counts.leave;
            document.getElementById('statLeavePct').innerText = getPct(counts.leave);
            document.getElementById('statEscapeCount').innerText = counts.escape;
            document.getElementById('statEscapePct').innerText = getPct(counts.escape);
            document.getElementById('totalStudentsCount').innerText = total;
        }

        async function submitAttendance() {
            const btn = document.getElementById('submitBtn');
            const subject = document.getElementById('subjectSelect').value;
            const room = document.getElementById('roomSelect').value;
            btn.disabled = true;
            btn.innerHTML = "กำลังบันทึกข้อมูล...";
            try {
                await fetch(SCRIPT_URL, {
                    method: 'POST',
                    mode: 'no-cors',
                    cache: 'no-cache',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        action: 'saveAttendance',
                        subject: subject,
                        room: room,
                        data: studentData
                    })
                });
                showModal("บันทึกสำเร็จ", "ข้อมูลถูกส่งเข้าระบบแล้ว", "🚀");
            } catch (error) {
                showModal("แจ้งเตือน", "ตรวจสอบข้อมูลใน Sheet อีกครั้ง", "✅");
            } finally {
                btn.disabled = false;
                btn.innerHTML = "บันทึกการเช็คชื่อ";
            }
        }

        function toggleLoading(show, text = "") {
            document.getElementById('loadingText').innerText = text;
            document.getElementById('loading').classList.toggle('hidden', !show);
            if(show) {
                document.getElementById('studentTableContainer').classList.add('hidden');
                document.getElementById('emptyState').classList.add('hidden');
            }
        }

        function showModal(title, message, icon) {
            document.getElementById('modalTitle').innerText = title;
            document.getElementById('modalMessage').innerText = message;
            document.getElementById('modalIcon').innerText = icon;
            document.getElementById('statusModal').classList.remove('hidden');
        }

        function closeModal() { document.getElementById('statusModal').classList.add('hidden'); }

        function updateTime() {
            document.getElementById('currentTime').innerText = new Date().toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit' });
        }
        setInterval(updateTime, 1000);
        updateTime();
        window.addEventListener('load', initApp);
    </script>
</body>
</html>
